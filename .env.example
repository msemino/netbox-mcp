# Base URL of your NetBox instance (no trailing slash)
NETBOX_URL=http://netbox.internal:8090

# A READ-ONLY NetBox API token. Admin > API Tokens > uncheck "Write enabled".
NETBOX_TOKEN=replace-me

# Bind address and port for the MCP HTTP endpoint
HOST=0.0.0.0
PORT=8097

# Seconds to wait for NetBox before giving up
NETBOX_TIMEOUT=20
